# Uncomment this line to define a global platform for your project
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig and running flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  # Patch BetterPlayer.h in the pub cache to suppress Xcode 16 selector-naming warnings.
  # The header is processed in the Runner target's context so pod-level OTHER_CFLAGS alone
  # isn't enough — wrapping the file in a diagnostic push/pop is the definitive fix.
  better_player_header = File.expand_path('~/.pub-cache/hosted/pub.dev/river_player-0.1.4/ios/Classes/BetterPlayer.h')
  if File.exist?(better_player_header)
    content = File.read(better_player_header)
    unless content.include?('Wmissing-selector-name')
      patched = "#pragma clang diagnostic push\n" \
                "#pragma clang diagnostic ignored \"-Wmissing-selector-name\"\n" \
                "#pragma clang diagnostic ignored \"-Wincomplete-implementation\"\n" \
                + content + \
                "\n#pragma clang diagnostic pop\n"
      File.write(better_player_header, patched)
      puts "✓ Patched BetterPlayer.h for Xcode 16 compatibility"
    end
  end

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      config.build_settings['SWIFT_VERSION'] = '5.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'

      # Fix: ensure every pod can find Flutter/Flutter.h
      framework_paths = config.build_settings['FRAMEWORK_SEARCH_PATHS']
      flutter_path = '"$(SRCROOT)/../Flutter"'
      built_path   = '"$(BUILT_PRODUCTS_DIR)"'
      if framework_paths.is_a?(Array)
        config.build_settings['FRAMEWORK_SEARCH_PATHS'] |= [flutter_path, built_path]
      elsif framework_paths.is_a?(String)
        config.build_settings['FRAMEWORK_SEARCH_PATHS'] = [framework_paths, flutter_path, built_path].join(' ')
      else
        config.build_settings['FRAMEWORK_SEARCH_PATHS'] = ["$(inherited)", flutter_path, built_path]
      end

      # Fix: disable warnings-as-errors for river_player pod target
      if target.name == 'river_player'
        config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        config.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        config.build_settings['OTHER_CFLAGS'] = '$(inherited) -w'
        config.build_settings['WARNING_CFLAGS'] = ''
      end

      # Fix: BetterPlayer.h is also processed in the Runner target context, so suppress
      # the -Wmissing-selector-name warning there too.
      if target.name == 'Runner'
        existing = config.build_settings['OTHER_CFLAGS'] || '$(inherited)'
        unless existing.include?('-Wno-missing-selector-name')
          config.build_settings['OTHER_CFLAGS'] = "#{existing} -Wno-missing-selector-name"
        end
      end
    end
  end
end
